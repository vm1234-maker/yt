# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Celery via Upstash (required)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI APIs (filled in Phase 3)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# YouTube (filled in Phase 3)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Other APIs (filled in Phase 3)
SUNO_API_KEY=
SERPAPI_KEY=
REPLICATE_API_TOKEN=

# Autonomous operation (optional — see plans/AUTONOMOUS-OPERATIONS.md)
# NEXT_PUBLIC_APP_URL=http://host.docker.internal:3000
AUTO_STRATEGY_WEEKLY=false
AUTO_APPROVE_AFTER_CONTENT=false
# Full pipeline on a schedule (Sundays 10:00 UTC) — use with care
AUTO_PIPELINE_WEEKLY=false

# Daily iMessage digest — run Celery Beat on macOS (not Linux Docker) so AppleScript can reach Messages
IMESSAGE_RECIPIENT=
