# FastAPI / Celery — deploy this folder to Railway, Render, Fly, etc. (not Vercel).
# Next.js + Vercel env vars live in repo root `.env.example` (NEXT_PUBLIC_*, BACKEND_URL).
#
# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NemoClaw sandbox only — where `nemoclaw_cli.py trigger-agent` POSTs (Next.js).
# Leave unset for local dev (install script defaults to host.docker.internal:3000).
# Set to your Vercel URL when the manager should hit production:
# NEMOCLAW_NEXT_APP_URL=https://YOUR_PROJECT.vercel.app

# Redis / Celery via Upstash (required)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI APIs (filled in Phase 3)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# YouTube (filled in Phase 3)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Other APIs (filled in Phase 3)
SUNO_API_KEY=
SERPAPI_KEY=
REPLICATE_API_TOKEN=

# Autonomous operation (optional — see plans/AUTONOMOUS-OPERATIONS.md)
# NEXT_PUBLIC_APP_URL=http://host.docker.internal:3000
AUTO_STRATEGY_WEEKLY=false
AUTO_APPROVE_AFTER_CONTENT=false
# Full pipeline on a schedule (Sundays 10:00 UTC) — use with care
AUTO_PIPELINE_WEEKLY=false

# Daily iMessage digest — run Celery Beat on macOS (not Linux Docker) so AppleScript can reach Messages
IMESSAGE_RECIPIENT=
