# =============================================================================
# Next.js — local: copy to `.env.local` | production: Vercel → Environment Variables
# =============================================================================
#
# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# FastAPI base URL — NO trailing slash. Scheme optional (bare host gets https:// in API routes).
# Local:  http://127.0.0.1:8000  (uvicorn in backend/)
# Production: set on **Vercel** to your Railway host, e.g. https://xxx.up.railway.app (Railway-only env is not enough).
BACKEND_URL=http://127.0.0.1:8000
#
# Optional — public URL of this Next app (links in emails, some tooling).
# Vercel: https://YOUR_PROJECT.vercel.app or your custom domain
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Where things run (so BACKEND_URL makes sense)
# =============================================================================
#
# • Vercel  → hosts THIS Next.js app only (dashboard + /api routes that proxy to FastAPI).
# • Railway / Render / Fly / Docker host → hosts FastAPI + Celery worker + beat if you use them.
#   After you deploy the backend, set BACKEND_URL in Vercel to that service’s HTTPS origin.
#
# You do NOT deploy FastAPI “on Vercel” for this stack: workers, Redis, and long jobs fit a
# Python container host (Railway/Render) better than Vercel’s serverless model.
