# Copy to ~/.openclaw/workspace/.env.nemoclaw inside the sandbox (or sync from Mac).
# Values mirror backend/.env + Next URL for Docker → host.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js from sandbox (required for trigger-agent) — must match OpenShell allowlist.
# Local Mac dev:
# NEXT_PUBLIC_APP_URL=http://host.docker.internal:3000
# Production (Vercel) — same value you set as NEMOCLAW_NEXT_APP_URL when pushing env:
# NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app
NEXT_PUBLIC_APP_URL=http://host.docker.internal:3000

# Optional — only used on macOS host; Linux sandbox skips iMessage
IMESSAGE_RECIPIENT=
