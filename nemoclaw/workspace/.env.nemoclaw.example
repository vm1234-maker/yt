# Copy to ~/.openclaw/workspace/.env.nemoclaw inside the sandbox (or sync from Mac).
# Values mirror backend/.env + Next URL for Docker → host.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js from sandbox (required for trigger-agent)
NEXT_PUBLIC_APP_URL=http://host.docker.internal:3000

# Optional — only used on macOS host; Linux sandbox skips iMessage
IMESSAGE_RECIPIENT=
